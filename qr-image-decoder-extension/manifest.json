{
  "manifest_version": 3,
  "name": "QR/Barcode Image Decoder",
  "version": "1.0.0",
  "description": "Decode QR codes and barcodes from an image copied to the clipboard.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "QR/Barcode Image Decoder",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
