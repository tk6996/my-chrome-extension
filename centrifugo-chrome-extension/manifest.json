{
  "manifest_version": 3,
  "name": "Centrifugo Debug Client",
  "version": "1.0.0",
  "description": "Connect to a Centrifugo server over WebSocket, subscribe to channels, publish messages, and inspect real-time traffic.",
  "action": {
    "default_title": "Open Centrifugo Debug Client",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "tabs"]
}
